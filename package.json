{
  "name": "@seamlyme/core",
  "version": "0.1.0",
  "private": true,
  "license": "BSD-3-Clause-Clear",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "seamlyme-core": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && npm run build:browser",
    "build:browser": "esbuild src/browser.ts --bundle --format=iife --global-name=SeamlyMECore --outfile=dist/browser/seamlyme-core.js",
    "cli": "npm run build --silent && node dist/cli.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "gts lint",
    "clean": "gts clean",
    "compile": "tsc",
    "docs": "typedoc",
    "fix": "gts fix",
    "prepare": "npm run compile",
    "pretest": "npm run compile",
    "posttest": "npm run lint"
  },
  "dependencies": {
    "expr-eval": "^2.0.2",
    "fast-xml-parser": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "esbuild": "^0.21.5",
    "gts": "^7.0.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.6.3",
    "vitest": "^1.6.0"
  }
}
